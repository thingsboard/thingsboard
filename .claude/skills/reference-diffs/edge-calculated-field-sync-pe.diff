diff --git a/application/src/main/java/org/thingsboard/server/service/cloud/rpc/processor/CalculatedFieldCloudProcessor.java b/application/src/main/java/org/thingsboard/server/service/cloud/rpc/processor/CalculatedFieldCloudProcessor.java
